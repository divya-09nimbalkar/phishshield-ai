{
  "manifest_version": 3,
  "name": "PhishShield",
  "version": "1.0",
  "description": "Detect phishing websites using AI",

  "permissions": ["tabs", "activeTab"],

  "host_permissions": [
    "http://127.0.0.1:8000/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}